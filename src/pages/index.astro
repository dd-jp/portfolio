---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import CaseStudies from '../components/CaseStudies.astro';
import Tabs from '../components/Tabs.astro';
import Skills from '../components/Skills.astro';
import Work from '../components/Work.astro';
import Education from '../components/Education.astro';
---

<Layout title="Deepak David - Lead UI Developer">
  <div class="min-h-screen">
    <Header />
    <main>
      <Hero />
      <Tabs />

      <div class="tab-section" id="skills" aria-hidden="true">
        <Skills />
      </div>

      <div class="tab-section" id="experience" aria-hidden="true">
        <Work />
      </div>

      <div class="tab-section" id="education" aria-hidden="true">
        <Education />
      </div>

      <div class="tab-section" id="architectural-work" aria-hidden="true">
        <CaseStudies />
      </div>
    </main>
  </div>
</Layout>
