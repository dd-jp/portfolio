---
const architecturalCompetencies = {
  "System Architecture": [
    "Micro-frontends",
    "Monorepos/TurboRepo",
    "Design Systems",
    "Next.js Strategy"
  ],
  "Quality & DevOps": [
    "CI/CD Pipelines",
    "Automated Testing Strategy",
    "Accessibility Compliance/Axe",
    "Docker/K8s"
  ],
  "Core Engineering": [
    "React/Native Ecosystem",
    "TypeScript",
    "Performance Optimization",
    "Cloud Foundry"
  ]
};
---

<section class="py-10" id="technical-strategy">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-4 mb-12">
      <svg class="w-8 h-8 text-gray-700 dark:text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
      </svg>
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white">Architectural Competencies</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {Object.entries(architecturalCompetencies).map(([category, items]) => (
        <div class="bg-white dark:bg-gray-800/50 rounded-lg p-8 border border-gray-200 dark:border-gray-700 hover:border-gray-300 dark:hover:border-gray-600 transition-colors duration-300">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-6">{category}</h3>
          <ul class="space-y-3">
            {items.map(item => (
              <li class="flex items-start gap-3">
                <span class="flex-shrink-0 mt-1 w-2 h-2 bg-blue-600 rounded-full"></span>
                <span class="text-gray-700 dark:text-gray-300">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
