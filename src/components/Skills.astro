---
const skills = {
        "Planning": [
            "Architecture Design",
            "Technical Leadership",
            "Team Building"
        ],
        "Implementation": [
            "React.js",
            "React Native",
            "Next.js",
            "Astro",
            "TypeScript",
            "TanStack Query",
            "Tailwind CSS",
            "Vite",
            "Storybook",
            "Monorepo",
            "TurboRepo"
        ],
        "Testing": [
            "Cypress",
            "Jest/Vitest",
            "React Testing Library",
            "Storybook Visual tests",
        ],
        "CI/CD": [
            "Jenkins, Netlify, GitHub Actions",
            "Cloud Foundry",
            "Docker",
            "Kubernetes"
        ]
    }
;
---

<section class="py-10" id="skills">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-4 mb-12">
      <svg class="w-8 h-8 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
      </svg>
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white">Skills</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {Object.entries(skills).map(([category, skillList]) => (
        <div class="bg-gray-50 dark:bg-gray-800/50 rounded-lg p-6 hover:bg-gray-100 dark:hover:bg-gray-800/70 transition-colors duration-300">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">{category}</h3>
          <ul class="space-y-2">
            {skillList.map(skill => (
              <li class="text-gray-700 dark:text-gray-300 flex items-center gap-2">
                <span class="text-blue-500 dark:text-blue-400">•</span>
                {skill}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
