  {
    name: 'GitHub',
    url: 'https://github.com/dd-jp',
    icon: `<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>`,
  },
  {
    name: 'LinkedIn',
    url: 'https://www.linkedin.com/in/jpdd08/',
    icon: `<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"></path>
          </svg>`,
  },
  {
    name: 'Email',
    url: 'mailto:dpkdavid@yahoo.com',
    icon: `<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm-.4 4.25l-7.07 4.42c-.32.2-.74.2-1.06 0L4.4 8.25c-.25-.16-.4-.43-.4-.72 0-.67.73-1.07 1.3-.72L12 11l6.7-4.19c.57-.35 1.3.05 1.3.72 0 .29-.15.56-.4.72z"/>
          </svg>`,
  },
];
---

<section class="pt-24 flex items-center">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-[144px_1fr] gap-12 items-start">
      <div class="relative max-w-[144px] mx-auto lg:mx-0">
        <div class="aspect-square rounded-full overflow-hidden border-4 border-gray-200 dark:border-gray-800">
          <img
            src="/profile-image.jpg"
            alt="Deepak David"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="mt-6 flex gap-4 justify-center">
          {socialLinks.map(link => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors"
              aria-label={link.name}
            >
              <Fragment set:html={link.icon} />
            </a>
          ))}
        </div>
      </div>

      <div class="py-4">
        <h1 class="text-5xl font-bold text-gray-900 dark:text-white mb-6 leading-tight">
          Architecting Scalable, Enterprise-Grade UI Systems.
        </h1>
        <h2 class="text-xl text-gray-600 dark:text-gray-400 mb-8 leading-relaxed max-w-3xl">
          Lead UI Architect guiding high-performing teams in building robust, accessible, and performant digital products for Fintech leaders like JP Morgan & Barclays.
        </h2>
          <p class="text-lg text-gray-700 dark:text-gray-300 max-w-3xl leading-relaxed text-justify">
              <b>Seasoned Engineering Leader with 12 years experience in Front-End development</b>
              with expertise in architecting and delivering high-performance, enterprise-grade web and mobile applications.
              Renowned for mastering the React ecosystem and building highly scalable, maintainable UI architectures.
              Proven track record in defining strategic technical direction, establishing robust engineering practices and fostering cross-functional collaboration to deliver innovative, user-centric digital products.
              Adept at mentoring and growing high-performing teams, driving efficiency through reusable design systems and aligning engineering execution with business strategy.
          </p>
        <div class="mb-8 mt-8">
          <a
            href="/Deepak_David_Resume.pdf"
            download
            class="inline-flex items-center justify-center px-8 py-3 border-2 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white font-semibold rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-200"
          >
            Download Resume
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
